{
  "expo": {
    "name": "Oscilla",
    "slug": "oscilla",
    "version": "1.0.0",
    "orientation": "landscape",
    "backgroundColor": "#010810",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#010810"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oscilla.app"
    },
    "android": {
      "package": "com.oscilla.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#010810"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE_LEFT"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b128a7e3-a44d-4759-bb6f-632ed8494eab"
      }
    }
  }
}