{
  "expo": {
    "name": "Oscilla",
    "slug": "oscilla",
    "scheme": "oscilla",
    "version": "1.0.0",
    "orientation": "landscape",
    "backgroundColor": "#010810",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#010810"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oscilla.app"
    },
    "android": {
      "package": "com.oscilla.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#010810"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://oscilla.app"
        }
      ],
      "expo-font",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "LANDSCAPE_LEFT"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fb80ada6-7e19-4d8d-997c-7d2cb29d564c"
      },
      "router": {
        "origin": "https://oscilla.app"
      }
    },
    "owner": "sheefti",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fb80ada6-7e19-4d8d-997c-7d2cb29d564c"
    }
  }
}
